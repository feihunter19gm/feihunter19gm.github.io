.makyo-home-content
  --makyo-blue: #071a3d
  --makyo-blue-2: #0d2c66
  --makyo-blue-3: #12458f
  --makyo-yellow: #ffd354
  --makyo-yellow-2: #ffb020
  --makyo-text: rgba(255, 255, 255, .9)
  --makyo-muted: rgba(255, 255, 255, .68)
  color: var(--makyo-text)

#recent-posts
  .recent-post-item
    border: 1px solid rgba(255, 211, 84, .16)
    background: linear-gradient(145deg, rgba(10, 25, 54, .96), rgba(7, 13, 30, .94))

    .article-title
      color: rgba(255, 255, 255, .96) !important

    .content
      color: rgba(255, 255, 255, .68)

#aside-content
  .card-widget
    border: 1px solid rgba(255, 211, 84, .16)
    background: linear-gradient(145deg, rgba(10, 25, 54, .96), rgba(7, 13, 30, .94))
    color: rgba(255, 255, 255, .78)

  .item-headline
    color: rgba(255, 255, 255, .92)

    i
      color: #ffd354

  .aside-list > .aside-list-item:not(:last-child)
    border-bottom-color: rgba(255, 211, 84, .16)

  .author-info-name,
  .headline,
  .length-num,
  .aside-list .title
    color: rgba(255, 255, 255, .9) !important

  .card-info #card-info-btn
    border: 1px solid rgba(255, 211, 84, .32)
    background: linear-gradient(135deg, #ffd354, #ffb020)
    color: #071a3d

.makyo-music,
.makyo-portal,
.makyo-rank,
.makyo-links
  margin-bottom: 20px
  border: 1px solid rgba(255, 211, 84, .16)
  border-radius: 12px
  background: linear-gradient(145deg, rgba(10, 25, 54, .96), rgba(7, 13, 30, .94))
  box-shadow: 0 14px 36px rgba(3, 10, 26, .28), inset 0 1px 0 rgba(255, 211, 84, .08)

.makyo-music
  display: grid
  grid-template-columns: auto minmax(120px, .7fr) minmax(150px, .7fr) minmax(190px, .8fr)
  align-items: center
  gap: 14px
  padding: 15px 20px

.makyo-music__icon
  display: grid
  place-items: center
  width: 38px
  height: 38px
  border-radius: 50%
  background: linear-gradient(135deg, var(--makyo-yellow), var(--makyo-yellow-2))
  color: var(--makyo-blue)

.makyo-music__meta
  display: grid
  gap: 3px

  span
    color: var(--makyo-yellow)
    font-size: .62em
    font-weight: bold
    letter-spacing: .12em

  strong
    color: var(--makyo-text)
    font-size: .9em

.makyo-music__player
  width: 100%
  height: 34px

.makyo-music__picker
  display: flex
  align-items: center
  gap: 6px

.makyo-music__select
  min-width: 0
  width: 100%
  height: 34px
  padding: 0 8px
  border: 1px solid rgba(255, 211, 84, .24)
  border-radius: 5px
  background: rgba(3, 12, 30, .56)
  color: var(--makyo-text)
  font-size: .75em

.makyo-music__nav
  display: flex
  gap: 3px

  button
    width: 28px
    height: 28px
    border-radius: 4px
    background: rgba(255, 211, 84, .13)
    color: var(--makyo-yellow)

    &:disabled
      cursor: not-allowed
      opacity: .45

.makyo-portal
  padding: 26px

.makyo-portal__head,
.makyo-rank__head,
.makyo-links__head
  display: flex
  align-items: flex-end
  justify-content: space-between
  gap: 20px
  margin-bottom: 20px

  h2
    margin: 3px 0 0
    color: #fff
    font-size: 1.55em

  > p
    margin: 0
    color: var(--makyo-muted)
    font-size: .86em

.makyo-portal__eyebrow
  color: var(--makyo-yellow)
  font-size: .66em
  font-weight: bold
  letter-spacing: .13em

.makyo-portal__grid
  display: grid
  grid-template-columns: 1fr
  gap: 16px

.makyo-portal__game,
.makyo-portal__download
  overflow: hidden
  border: 1px solid rgba(255, 211, 84, .14)
  border-radius: 12px
  background: radial-gradient(circle at 88% 12%, rgba(255, 211, 84, .14), transparent 32%), linear-gradient(135deg, rgba(13, 44, 102, .92), rgba(6, 17, 42, .95))
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, .06)

.makyo-portal__game
  display: grid
  grid-template-columns: 210px 1fr

  > img
    width: 210px
    height: 100%
    min-height: 148px
    object-fit: cover

.makyo-portal__game-copy,
.makyo-portal__download
  display: flex
  flex-direction: column
  align-items: flex-start
  padding: 18px

  > span
    color: var(--makyo-yellow)
    font-size: .69em
    font-weight: bold

  h3
    margin: 5px 0
    color: #fff
    font-size: 1.08em

  p
    margin: 0 0 13px
    color: var(--makyo-muted)
    font-size: .78em
    line-height: 1.6

  code
    color: var(--makyo-yellow)
    font-size: .86em

  .button--animated
    margin-top: auto
    padding: 6px 11px
    border: 1px solid rgba(255, 211, 84, .34)
    border-radius: 5px
    background: linear-gradient(135deg, var(--makyo-yellow), var(--makyo-yellow-2))
    color: var(--makyo-blue)
    font-size: .78em
    font-weight: bold

.makyo-portal__download
  border-style: dashed

  > i
    margin-bottom: 8px
    color: var(--makyo-yellow)
    font-size: 1.65em

.makyo-rank
  padding: 24px

.makyo-links
  padding: 24px

.makyo-links__grid
  display: grid
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr))
  gap: 12px

.makyo-links__item
  display: grid
  gap: 6px
  padding: 16px
  border: 1px solid rgba(255, 211, 84, .16)
  border-radius: 12px
  background: radial-gradient(circle at 88% 0, rgba(255, 211, 84, .13), transparent 32%), linear-gradient(135deg, rgba(13, 44, 102, .72), rgba(6, 17, 42, .9))
  color: rgba(255, 255, 255, .9)
  transition: transform .2s, border-color .2s, box-shadow .2s

  i
    color: var(--makyo-yellow)
    font-size: 1.25em

  span
    font-weight: bold

  small
    color: var(--makyo-muted)

  &:hover
    border-color: rgba(255, 211, 84, .38)
    color: var(--makyo-yellow)
    transform: translateY(-2px)
    box-shadow: 0 12px 26px rgba(0, 0, 0, .18)

.makyo-rank__table
  overflow: hidden
  border: 1px solid rgba(255, 211, 84, .16)
  border-radius: 12px
  background: linear-gradient(135deg, rgba(13, 44, 102, .72), rgba(6, 17, 42, .9))

.makyo-rank__row
  display: grid
  grid-template-columns: 64px 1fr 1.15fr 96px 100px
  gap: 10px
  align-items: center
  min-height: 46px
  padding: 10px 14px
  border-bottom: 1px solid rgba(255, 211, 84, .1)
  color: rgba(255, 255, 255, .78)
  font-size: .82em

  &:last-child
    border-bottom: 0

.makyo-rank__row--head
  min-height: 40px
  background: rgba(255, 211, 84, .11)
  color: var(--makyo-yellow)
  font-size: .72em
  font-weight: bold
  letter-spacing: .08em

.makyo-rank__place,
.makyo-rank__score
  color: var(--makyo-yellow)
  font-weight: bold

.makyo-rank__score
  text-align: right

.makyo-rank__empty
  padding: 18px
  color: var(--makyo-muted)
  text-align: center

.makyo-rank__caption
  margin: 10px 0 0
  color: var(--makyo-muted)
  font-size: .72em
  text-align: center

  code
    color: var(--makyo-yellow)

.makyo-gallery
  margin-bottom: 20px
  padding: 24px
  border: 1px solid rgba(255, 211, 84, .16)
  border-radius: 12px
  background: radial-gradient(circle at 18% 0, rgba(73, 177, 245, .25), transparent 34%), linear-gradient(145deg, var(--makyo-blue-2), var(--makyo-blue) 58%, #06112a)
  box-shadow: 0 14px 36px rgba(3, 10, 26, .28), inset 0 1px 0 rgba(255, 211, 84, .08)

.makyo-gallery__head
  display: flex
  align-items: flex-end
  justify-content: space-between
  gap: 20px
  margin-bottom: 16px

  h2
    margin: 3px 0 0
    color: #fff
    font-size: 1.35em

  p
    margin: 0
    color: var(--makyo-muted)
    font-size: .76em

.makyo-gallery__stage
  display: grid
  grid-template-columns: 42px minmax(0, 1fr) 42px
  align-items: center
  overflow: hidden
  min-height: 210px
  border: 1px solid rgba(255, 211, 84, .14)
  border-radius: 8px
  background: linear-gradient(135deg, var(--makyo-blue-3), var(--makyo-blue))

.makyo-gallery__image
  display: grid
  place-items: center
  overflow: hidden
  height: 100%
  min-height: 210px
  background: linear-gradient(rgba(10, 37, 86, .3), rgba(7, 26, 61, .72)), repeating-linear-gradient(45deg, rgba(255, 211, 84, .05) 0, rgba(255, 211, 84, .05) 1px, transparent 1px, transparent 14px)

  img
    width: 100%
    height: 100%
    max-height: 360px
    object-fit: contain
    transition: transform .3s

  &:hover img
    transform: scale(1.02)

.makyo-gallery__empty
  color: var(--makyo-muted)
  font-size: .8em

.makyo-gallery__arrow
  z-index: 1
  width: 32px
  height: 42px
  margin: auto
  border: 1px solid rgba(255, 211, 84, .2)
  border-radius: 5px
  background: rgba(5, 16, 40, .82)
  color: var(--makyo-yellow)
  font-size: 1.15em
  box-shadow: 0 2px 8px rgba(0,0,0,.1)

  &:disabled
    cursor: not-allowed
    opacity: .4

.makyo-gallery__caption
  margin: 10px 0 0
  color: var(--makyo-muted)
  font-size: .72em
  text-align: center

.card-makyo-support__content
  display: grid
  justify-items: center
  gap: 12px
  text-align: center

  p
    margin: 0
    font-size: .75em
    line-height: 1.65

  code
    color: var(--theme-color)
    font-size: .86em

.card-makyo-support__qr
  position: relative
  width: 150px
  height: 150px
  overflow: hidden
  border: 4px solid #fff
  border-radius: 10px
  background: #fff
  box-shadow: 0 8px 20px rgba(0, 0, 0, .16)

  img,
  span
    width: 100%
    height: 100%

  img
    position: relative
    z-index: 1
    object-fit: cover

  span
    position: absolute
    inset: 0
    display: grid
    place-items: center
    background: repeating-linear-gradient(45deg, #1b2530 0, #1b2530 7px, #f5f5f5 7px, #f5f5f5 12px)
    color: #fff
    font-size: .65em
    font-weight: bold

@media (max-width: 900px)
  .makyo-portal__game
    grid-template-columns: 140px 1fr

    > img
      width: 140px

@media (max-width: 768px)
  .makyo-music
    grid-template-columns: auto 1fr

  .makyo-music__picker,
  .makyo-music__player
    grid-column: span 2

@media (max-width: 600px)
  .makyo-portal
    padding: 18px

  .makyo-portal__head
    display: block

    > p
      margin-top: 8px

  .makyo-gallery
    padding: 18px

  .makyo-gallery__head,
  .makyo-rank__head,
  .makyo-links__head
    display: block

    p
      margin-top: 8px

  .makyo-gallery__stage,
  .makyo-gallery__image
    min-height: 180px

  .makyo-portal__game
    grid-template-columns: 100px 1fr

    > img
      width: 100px

  .makyo-music
    padding: 14px

  .makyo-rank
    padding: 18px

  .makyo-links
    padding: 18px

  .makyo-rank__row
    grid-template-columns: 48px 1fr 78px

    span:nth-child(3),
    span:nth-child(5)
      display: none
